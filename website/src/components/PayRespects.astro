---
interface Props {
  techId: string;
  techName: string;
  initialCount?: number;
}

const { techId, techName, initialCount = 0 } = Astro.props;
---

<div class="pay-respects-container" data-tech-id={techId} data-tech-name={techName}>
  <p>Total Respects Paid: <strong class="respect-count">{initialCount}</strong></p>
  <button type="button" class="pay-respects-btn">Press F to Pay Respects</button>
  <div class="respect-message" style="display: none;"></div>
</div>

<script>
  const containers = document.querySelectorAll('.pay-respects-container');

  containers.forEach(container => {
    const btn = container.querySelector('.pay-respects-btn') as HTMLButtonElement;
    const countDisplay = container.querySelector('.respect-count') as HTMLElement;
    const msgDisplay = container.querySelector('.respect-message') as HTMLElement;
    
    const techId = container.getAttribute('data-tech-id');
    const techName = container.getAttribute('data-tech-name');

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      btn.textContent = 'Paying Respects...';
      
      try {
        const supabaseUrl = import.meta.env.NEXT_PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || '';
        const anonKey = import.meta.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
        const functionUrl = `${supabaseUrl}/functions/v1/pay_respect`;
        
        const response = await fetch(functionUrl, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${anonKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ techId, techName }),
        });

        const result = await response.json();
        
        if (result.success) {
          countDisplay.textContent = result.count !== null ? result.count.toString() : (parseInt(countDisplay.textContent || '0') + 1).toString();
          msgDisplay.textContent = 'Respects paid successfully.';
          msgDisplay.style.color = 'green';
        } else {
          msgDisplay.textContent = result.error === 'FEATURE_DISABLED' ? 'This feature is currently disabled.' : 'Failed to pay respects.';
          msgDisplay.style.color = 'red';
        }
      } catch (err) {
        msgDisplay.textContent = 'An error occurred. Respects not paid.';
        msgDisplay.style.color = 'red';
      } finally {
        msgDisplay.style.display = 'block';
        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = 'Press F to Pay Respects';
        }, 2000);
      }
    });
  });
</script>

<style>
  .pay-respects-container {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid #ccc;
    text-align: center;
  }
  .pay-respects-btn {
    padding: 0.5rem 1rem;
    font-family: inherit;
    background: #eee;
    border: 1px solid #999;
    cursor: pointer;
    font-size: 1rem;
  }
  .pay-respects-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }
  .respect-message {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-style: italic;
  }
</style>

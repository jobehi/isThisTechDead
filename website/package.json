{
  "name": "is-this-tech-dead",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "check-env": "ts-node --project tsconfig.scripts.json scripts/src/check-env.ts",
    "predev": "npm run check-env",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "astro check && tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepare": "cd .. && husky",
    "clean": "rm -rf dist .astro",
    "build:fresh": "npm run clean && npm run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/lora": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.49.4",
    "astro": "^7.0.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/eslintrc": "^3",
    "@types/node": "^26.1.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.1.2"
  }
}
